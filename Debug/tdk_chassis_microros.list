bool PinpointI2C::writePosition(const Pose& p) {
    bool okx = writeF32(REG_POS_X, p.x_mm);
    bool oky = writeF32(REG_POS_Y, p.y_mm);
    bool okh = writeF32(REG_POS_H, p.heading);
    return okx && oky && okh;
}
